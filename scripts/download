#!/bin/bash

# Compute the suffix to identify the architecture
SUFFIX="$(uname -m)"
# Set the expected downloaded filename
EXPECTED_FILE="k3s"

# Modify the check to match the expected filename
if ! grep -q "$EXPECTED_FILE" <<< "$(basename "${1}")"; then
    echo "Downloaded file does not match expected file name: $EXPECTED_FILE"
    exit 1
fi

# Validate the checksum against the downloaded file
echo "$EXPECTED_FILE  ${1}" | sha256sum -c - || {
    echo "Checksum verification failed!";
    exit 1;
}

# Continue with the installation or other operations...